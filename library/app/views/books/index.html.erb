<h1>Books</h1>

<%= link_to "Add Book", new_book_path %> |
<%= link_to "Borrowers", borrowers_path %>

<table border="1">
  <tr>
    <th>Title</th>
    <th>Author</th>
    <th>Status</th>
    <th>Actions</th>
  </tr>

  <% @books.each do |book| %>
    <tr>
      <td><%= book.title %></td>
      <td><%= book.author %></td>
      <td><%= book.available ? "Available" : "Borrowed" %></td>

      <td>
        <%= link_to "Show", book_path(book) %>
        <%= link_to "Edit", edit_book_path(book) %>
        <%= link_to "Delete", book_path(book), method: :delete %>

        <% if book.available %>
          <%= form_with url: borrowings_path, method: :post do %>
            <%= hidden_field_tag :book_id, book.id %>
            <%= number_field_tag :borrower_id, nil, placeholder: "Borrower ID" %>
            <%= submit_tag "Borrow" %>
          <% end %>
        <% end %>
      </td>
    </tr>
  <% end %>
</table>