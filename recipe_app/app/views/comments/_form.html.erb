<%= form_with(model: [recipe, comment]) do |f| %>
  <div>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :user_id, "Commenter" %><br>
    <%= f.collection_select :user_id, users, :id, :name, prompt: "Select a user" %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
