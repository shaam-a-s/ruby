<%= form_with(model: @recipe) do |f| %>
  <div>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :ingredients %><br>
    <%= f.text_area :ingredients %>
  </div>

  <div>
    <%= f.label :user_id, "Author" %><br>
    <%= f.collection_select :user_id, @users, :id, :name, prompt: "Select a user" %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
