<h1>Course Detail</h1>

<p><strong>Name:</strong> <%= @course.name %></p>
<p><strong>Instructor:</strong> <%= @course.instructor %></p>

<h2>Lessons</h2>
<ul>
  <% @lessons.each do |lesson| %>
    <li><%= lesson.name %> - <%= lesson.description %></li>
  <% end %>
</ul>

<p>
  <%= link_to "Edit", edit_course_path(@course) %> |
  <%= link_to "Back", courses_path %>
</p>
