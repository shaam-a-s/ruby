<h1>Login</h1>

<p>Use a registered student email to sign in.</p>

<%= form_with url: login_path, method: :post, local: true do |form| %>
  <p>
    <%= form.label :email, "Email" %><br>
    <%= form.email_field :email, required: true %>
  </p>

  <p>
    <%= form.submit "Login" %>
  </p>
<% end %>

<p>
  New here?
  <%= link_to "Create student account", new_student_path %>
</p>
