<h1>Students</h1>

<p><%= link_to "New Student", new_student_path %></p>

<table border="1" cellpadding="6">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @students.each do |student| %>
      <tr>
        <td><%= student.name %></td>
        <td><%= student.email %></td>
        <td>
          <%= link_to "Show", student_path(student) %> |
          <%= link_to "Edit", edit_student_path(student) %> |
          <%= button_to "Delete", student_path(student), method: :delete, data: { turbo_confirm: "Delete this student?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
